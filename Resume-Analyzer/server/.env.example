# Server Configuration
# PORT: The door where your server listens for requests (default 5000)
# NODE_ENV: Set to 'development' for coding and 'production' for shipping
PORT=5000
NODE_ENV=development

# Database Configuration
# MONGO_URI: Get this from your MongoDB Atlas dashboard (Project -> Database -> Connect)
# Example: mongodb+srv://<user>:<password>@cluster.mongodb.net/resumeDB
MONGO_URI=mongodb://localhost:27017/resume-analyzer

# AI Configuration (Crucial for Analysis)
# GEMINI_API_KEY: Go to https://aistudio.google.com/ and create a FREE key.
GEMINI_API_KEY=your_google_gemini_api_key_here

# Security (JWT - JSON Web Token)
# JWT_SECRET: A secret password used to sign user login tokens. 
# Keep this very long and very secret!
JWT_SECRET=super_secret_key_12345
